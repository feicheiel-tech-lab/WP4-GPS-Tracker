<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="17dp"
    android:background="@drawable/notification_bg">

    <TextView
        android:id="@+id/txt_ntf_title"
        android:text="@string/notification_title"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="17sp"
        android:fontFamily="@font/source_sans_pro_bold"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/txt_ntf_text"
        android:text="@string/notification_text"
        android:textColor="?android:attr/textColorPrimary"
        android:fontFamily="@font/source_sans_pro_regular"
        android:layout_below="@id/txt_ntf_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/txt_ntf_stats"
        android:text="0.00 km | 0 pts"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp"
        android:fontFamily="@font/source_sans_pro_light"
        android:layout_below="@id/txt_ntf_text"
        android:layout_marginTop="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Indicator -->
    <ImageView
        android:id="@+id/notification_statusDot"
        android:layout_width="13dp"
        android:layout_height="13dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:contentDescription="@string/str_ntf_about_statusDot"
        android:src="@drawable/notification_indicator_orange"/>
</RelativeLayout>